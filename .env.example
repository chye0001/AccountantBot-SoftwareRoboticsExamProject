# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=development

# Discord
DISCORD_LOG_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_ACCOUNTANT_ROLE_ID=YOUR_DISCORD_ACCOUNTANT_ROLE_ID

# LLM (any OpenAI-compatible /chat/completions endpoint)
# Examples:
#   OpenAI:     https://api.openai.com/v1          model: gpt-4o-mini
#   Groq:       https://api.groq.com/openai/v1     model: llama-3.2-90b-vision-preview
#   OpenRouter: https://openrouter.ai/api/v1       model: anthropic/claude-3.5-sonnet
#   Anthropic:  https://api.anthropic.com/v1       model: claude-3-5-sonnet-latest
#   Ollama:     http://host.docker.internal:11434/v1   model: llava
# Model must support vision (image input).
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=gpt-4o-mini

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID=YOUR_GOOGLE_SHEETS_SPREADSHEET_ID
GOOGLE_SHEETS_SHEET_NAME=Expenses

# MongoDB logging
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_this_password
MONGO_DATABASE=expense_rpa
MONGO_LOG_COLLECTION=workflow_logs
