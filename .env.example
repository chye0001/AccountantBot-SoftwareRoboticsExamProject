# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=development

# Discord
DISCORD_LOG_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
DISCORD_ACCOUNTANT_ROLE_ID=YOUR_DISCORD_ACCOUNTANT_ROLE_ID

# Anthropic / Claude
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Excel / Microsoft Graph
EXCEL_WORKBOOK_ITEM_ID=YOUR_ONEDRIVE_WORKBOOK_ITEM_ID
EXCEL_EXPENSE_TABLE_NAME=Expenses

# MongoDB logging
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_this_password
MONGO_DATABASE=expense_rpa
MONGO_LOG_COLLECTION=workflow_logs